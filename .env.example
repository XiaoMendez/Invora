# ============================================
# INVORA - Environment Variables Configuration
# ============================================
# Copy this file to .env.local and fill in your values
# For production, set these in your hosting provider's environment settings

# ============================================
# SITE CONFIGURATION
# ============================================
# Your application's base URL (used for auth redirects and callbacks)
NEXT_PUBLIC_SITE_URL="https://invorastock.vercel.app"

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from your Supabase project dashboard:
# https://app.supabase.com/project/_/settings/api

# Supabase Project URL (Public)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_URL="https://your-project-id.supabase.co"

# Supabase Anonymous Key (Public - safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_ANON_KEY="your-anon-key"

# Supabase Service Role Key (SECRET - Server-side only, NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Supabase JWT Secret (SECRET - For custom JWT verification)
SUPABASE_JWT_SECRET="your-jwt-secret"

# ============================================
# DATABASE CONFIGURATION (PostgreSQL)
# ============================================
# Get these from Supabase: Project Settings > Database > Connection string
# Or use your own PostgreSQL instance

# Primary database connection (uses connection pooling)
POSTGRES_URL="postgres://postgres.[project-ref]:[password]@[host]:6543/postgres?sslmode=require"

# For Prisma ORM (with PgBouncer pooling)
POSTGRES_PRISMA_URL="postgres://postgres.[project-ref]:[password]@[host]:6543/postgres?sslmode=require&pgbouncer=true"

# Direct connection without pooling (for migrations)
POSTGRES_URL_NON_POOLING="postgres://postgres.[project-ref]:[password]@[host]:5432/postgres?sslmode=require"

# Alternative: DATABASE_URL (fallback for standard PostgreSQL connections)
DATABASE_URL="postgres://postgres.[project-ref]:[password]@[host]:6543/postgres?sslmode=require"

# Individual PostgreSQL credentials (optional, for custom connections)
POSTGRES_HOST="db.your-project-id.supabase.co"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="your-password"
POSTGRES_DATABASE="postgres"

# ============================================
# AUTHENTICATION
# ============================================
# Secret key for session encryption (generate a secure random string)
# You can generate one with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-min-32-characters"

# ============================================
# AI SERVICES (Optional)
# ============================================
# For AI features, set up your preferred provider

# Anthropic (Claude)
ANTHROPIC_AUTH_TOKEN="your-anthropic-token"

# Vercel AI Gateway (unified AI access)
AI_GATEWAY_API_KEY="your-ai-gateway-key"

# ============================================
# ANALYTICS (Optional)
# ============================================
# Vercel Web Analytics
VERCEL_WEB_ANALYTICS_ID="your-analytics-id"

# ============================================
# MIGRATION GUIDE
# ============================================
# To migrate to another host:
#
# 1. UPDATE SITE URL:
#    - Change NEXT_PUBLIC_SITE_URL to your new domain
#    - Update Supabase auth redirect URLs in your project settings
#
# 2. SUPABASE MIGRATION:
#    - Export your Supabase project data
#    - Update NEXT_PUBLIC_SUPABASE_URL and SUPABASE_URL to new project URL
#    - Update all SUPABASE_* keys from the new project dashboard
#
# 3. DATABASE MIGRATION:
#    - Export your PostgreSQL database: pg_dump -Fc your_db > backup.dump
#    - Import to new database: pg_restore -d new_db backup.dump
#    - Update POSTGRES_URL and related variables to new connection strings
#
# 4. SELF-HOSTED PostgreSQL:
#    - Set DATABASE_URL to your PostgreSQL connection string
#    - Ensure SSL is configured if required
#    - Update POSTGRES_HOST, POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DATABASE
#
# 5. OTHER PROVIDERS (Railway, PlanetScale, Neon, etc.):
#    - Each provider will give you a connection string
#    - Set POSTGRES_URL or DATABASE_URL accordingly
#    - For Supabase Auth features, you'll need to implement custom auth
#      or use a compatible auth provider
